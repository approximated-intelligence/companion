<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (minSdk 31).
    Cloud backup: only when encrypted (SeedVault, encrypted Google backup).
    Device transfer: same rules - credentials are device-bound.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <!-- Room database -->
        <include domain="database" path="companion.db" />
        <include domain="database" path="companion.db-wal" />
        <include domain="database" path="companion.db-shm" />

        <!-- Non-secret config (journey, B2 addressing, GitHub repo, NaCl pubkey, site URL) -->
        <include domain="sharedpref" path="app_prefs.xml" />

        <!-- Backup schedule (non-secret) -->
        <include domain="sharedpref" path="." />

        <!-- Exclude device-bound encrypted secrets -->
        <exclude domain="sharedpref" path="encrypted_creds.xml" />

        <!-- Exclude legacy plaintext store if migration hasn't completed -->
        <exclude domain="sharedpref" path="backup_creds.xml" />
    </cloud-backup>

    <device-transfer>
        <include domain="database" path="companion.db" />
        <include domain="database" path="companion.db-wal" />
        <include domain="database" path="companion.db-shm" />
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="encrypted_creds.xml" />
        <exclude domain="sharedpref" path="backup_creds.xml" />
    </device-transfer>
</data-extraction-rules>
